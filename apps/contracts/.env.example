# Somnia Testnet Configuration
# Copy this to .env and fill in your values

# Your wallet private key (DO NOT commit .env to git!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Somnia Testnet RPC
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# House wallet address (receives betting fees and sponsorship share)
HOUSE_WALLET=0xYOUR_HOUSE_WALLET_ADDRESS

# Game server address (authorized to create/resolve matches)
GAME_SERVER_ADDRESS=0xYOUR_GAME_SERVER_ADDRESS
